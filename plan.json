  "progression_rules": {
    "description": "渐进超负荷规则 — 每次训练尝试比上次多一点",
    "rules": [
      "当某动作连续 2 次训练都能完成最高次数（如 3×12）时，下次加重 2.5kg（复合动作）或 1kg（孤立动作）",
      "加重后目标次数范围下调（如 12→8），逐步再推回最高次数",
      "如果某动作连续 3 次无法进步，降重 10% 做 deload 周，然后重新推进",
      "有氧：每 2 周尝试坡度+1 或速度+0.5"
    ],
    "weight_increment": {
      "compound": 2.5,
      "isolation": 1,
      "bodyweight": "加次数或加难度变体"
    }
  },
  "warmup_protocol": {
    "description": "每次训练前必做，约 5-8 分钟",
    "steps": [
      "5 分钟低强度有氧（快走/椭圆机）提升心率",
      "动态拉伸：手臂画圈×10、腿摆×10、躯干旋转×10",
      "目标肌群激活：空动作或弹力带热身 1-2 组",
      "第一个动作：先做 1-2 组轻重量热身组（50%-70% 工作重量）"
    ]
  },
  "deload_protocol": {
    "trigger": "连续 2 周体重不降 或 训练连续 3 次无进步 或 主观疲劳感持续偏高",
    "actions": [
      "训练量减半（组数×0.5，重量不变）",
      "热量维持（不增不减）1 周",
      "优先保证睡眠 7-8 小时",
      "1 周后恢复正常"
    ]
  },
